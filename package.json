{
    "name": "react-electron-template",
    "version": "0.0.2",
    "main": "dist_electron/main.js",
    "repository": "https://github.com/vanner-young/react-electron-template.git",
    "author": "vanner-young <vanneryoung@gmail.com>",
    "license": "MIT",
    "keywords": [
        "react",
        "zustand",
        "i18n",
        "eslint",
        "electron",
        "axios",
        "typescript",
        "husky",
        "lint-staged",
        "prettier",
        "website"
    ],
    "scripts": {
        "start": "mv-cli start",
        "build": "tsc -b && mv-cli build",
        "lint": "eslint src electron --ext .js,.jsx,.ts,.tsx",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\" \"electron/**/*.{js,ts,json}\"",
        "prepare": "husky"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^7.16.0",
        "@typescript-eslint/parser": "^7.16.0",
        "@vite-electron-simple/common": "^2.0.0",
        "@vite-electron-simple/core": "^2.0.0",
        "@vitejs/plugin-react": "^6.0.2",
        "electron": "^42.4.1",
        "electron-builder": "^26.15.3",
        "esbuild": "^0.28.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "husky": "^9.1.0",
        "lint-staged": "^15.2.7",
        "prettier": "^3.3.2",
        "tailwindcss": "^4.3.1",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "@ant-design/x": "^2.8.0",
        "ahooks": "^3.8.5",
        "antd": "^6.4.4",
        "axios": "^1.7.7",
        "events": "^3.3.0",
        "lodash": "^4.17.21",
        "mv-common": "^1.1.7",
        "mv-tsc-watch": "^0.0.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router-dom": "^7.18.0",
        "typescript": "^5.5.3",
        "zustand": "^5.0.14"
    }
